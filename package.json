{
  "name": "content-creation-tool",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "cookie@<0.7.0": "0.7.2",
    "ws@8.0.0 - 8.20.1": "8.21.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.18",
    "@clerk/ui": "^1.25.3",
    "@neondatabase/serverless": "^1.1.0",
    "@studio/prompts": "file:packages/prompts",
    "@trigger.dev/build": "4.5.4",
    "@trigger.dev/sdk": "4.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "openai": "^6.47.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^1.0.0-rc.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "trigger.dev": "4.5.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
