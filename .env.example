# Public application configuration
APP_NAME=VCStudio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk browser-visible configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Clerk server-only configuration
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon PostgreSQL server-only configuration
# Use the pooled URL at application runtime.
DATABASE_URL=
# Prefer the direct/unpooled URL for migrations.
DATABASE_URL_UNPOOLED=
# Opt in only when running the isolated development-database invariant suite.
RUN_DATABASE_INTEGRATION_TESTS=false

# Cloudflare R2 private object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_SIGNED_UPLOAD_EXPIRY_SECONDS=300
R2_SIGNED_DOWNLOAD_EXPIRY_SECONDS=300

# Phase 4 character reference uploads
MAX_CHARACTER_REFERENCE_SIZE_BYTES=5242880
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
MIN_REFERENCE_IMAGE_WIDTH=512
MIN_REFERENCE_IMAGE_HEIGHT=512
MAX_REFERENCE_IMAGE_WIDTH=4096
MAX_REFERENCE_IMAGE_HEIGHT=4096
ENABLE_CHARACTER_LIBRARY=true

# Project and script limits
MAX_SCRIPT_CHARACTERS=50000
DEFAULT_PROJECT_BUDGET_CENTS=200

# Phase 3 scene analysis (server only)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-luna
OPENAI_TEXT_INPUT_COST_PER_MILLION_CENTS=100
OPENAI_TEXT_OUTPUT_COST_PER_MILLION_CENTS=600
OPENAI_REQUEST_TIMEOUT_SECONDS=180
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=
IDEMPOTENCY_HASH_SECRET=
REQUEST_FINGERPRINT_SECRET=
MAX_SCENES_PER_PROJECT=200
MIN_SCENE_DURATION_MILLISECONDS=1000
MAX_SCENE_DURATION_MILLISECONDS=60000
MAX_SCENE_ANALYSIS_RETRIES=2
GENERATION_RESERVATION_EXPIRY_MINUTES=30
DEFAULT_DAILY_BUDGET_CENTS=500
DEFAULT_MONTHLY_BUDGET_CENTS=5000

# Phase 5 scene image generation (server and Trigger.dev)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_DRAFT_QUALITY=low
OPENAI_IMAGE_FINAL_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=webp
OPENAI_IMAGE_DRAFT_COMPRESSION=80
OPENAI_IMAGE_FINAL_COMPRESSION=90
OPENAI_IMAGE_BACKGROUND=opaque
OPENAI_IMAGE_TEXT_INPUT_COST_PER_MILLION_CENTS=500
OPENAI_IMAGE_INPUT_COST_PER_MILLION_CENTS=800
OPENAI_IMAGE_OUTPUT_COST_PER_MILLION_CENTS=3000
OPENAI_IMAGE_LOW_SQUARE_ESTIMATE_CENTS=2
OPENAI_IMAGE_LOW_RECTANGULAR_ESTIMATE_CENTS=2
OPENAI_IMAGE_MEDIUM_SQUARE_ESTIMATE_CENTS=6
OPENAI_IMAGE_MEDIUM_RECTANGULAR_ESTIMATE_CENTS=7
OPENAI_IMAGE_HIGH_SQUARE_ESTIMATE_CENTS=20
OPENAI_IMAGE_HIGH_RECTANGULAR_ESTIMATE_CENTS=25
OPENAI_IMAGE_REFERENCE_RESERVE_CENTS_PER_ASSET=1
MAX_IMAGE_GENERATION_RETRIES=1
MAX_REFERENCE_ASSETS_PER_GENERATION=8
MAX_REFERENCE_BYTES_PER_GENERATION=20971520
MAX_IMAGE_GENERATIONS_PER_SCENE_VERSION=50
ENABLE_SCENE_IMAGE_GENERATION=true

# Phase 6 storyboard bulk image generation (server only)
MAX_IMAGES_PER_BATCH=25
