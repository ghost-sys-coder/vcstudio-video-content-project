# Public application configuration
APP_NAME=VCStudio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk browser-visible configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Clerk server-only configuration
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon PostgreSQL server-only configuration
# Use the pooled URL at application runtime.
DATABASE_URL=
# Prefer the direct/unpooled URL for migrations.
DATABASE_URL_UNPOOLED=
# Opt in only when running the isolated development-database invariant suite.
RUN_DATABASE_INTEGRATION_TESTS=false

# Cloudflare R2 private object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_SIGNED_UPLOAD_EXPIRY_SECONDS=300
R2_SIGNED_DOWNLOAD_EXPIRY_SECONDS=300

# Phase 4 character reference uploads
MAX_CHARACTER_REFERENCE_SIZE_BYTES=5242880
ALLOWED_IMAGE_MIME_TYPES=image/png,image/jpeg,image/webp
MIN_REFERENCE_IMAGE_WIDTH=512
MIN_REFERENCE_IMAGE_HEIGHT=512
MAX_REFERENCE_IMAGE_WIDTH=4096
MAX_REFERENCE_IMAGE_HEIGHT=4096
ENABLE_CHARACTER_LIBRARY=true

# Project and script limits
MAX_SCRIPT_CHARACTERS=50000
DEFAULT_PROJECT_BUDGET_CENTS=500

# Phase 3 scene analysis (server only)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-luna
OPENAI_TEXT_INPUT_COST_PER_MILLION_CENTS=100
OPENAI_TEXT_OUTPUT_COST_PER_MILLION_CENTS=600
OPENAI_REQUEST_TIMEOUT_SECONDS=180
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=
IDEMPOTENCY_HASH_SECRET=
REQUEST_FINGERPRINT_SECRET=
MAX_SCENES_PER_PROJECT=200
MIN_SCENE_DURATION_MILLISECONDS=1000
MAX_SCENE_DURATION_MILLISECONDS=60000
MAX_SCENE_ANALYSIS_RETRIES=2
GENERATION_RESERVATION_EXPIRY_MINUTES=30
DEFAULT_DAILY_BUDGET_CENTS=500
DEFAULT_MONTHLY_BUDGET_CENTS=5000

# Phase 5 scene image generation (server and Trigger.dev)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_DRAFT_QUALITY=low
OPENAI_IMAGE_FINAL_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=webp
OPENAI_IMAGE_DRAFT_COMPRESSION=80
OPENAI_IMAGE_FINAL_COMPRESSION=90
OPENAI_IMAGE_BACKGROUND=opaque
OPENAI_IMAGE_TEXT_INPUT_COST_PER_MILLION_CENTS=500
OPENAI_IMAGE_INPUT_COST_PER_MILLION_CENTS=800
OPENAI_IMAGE_OUTPUT_COST_PER_MILLION_CENTS=3000
OPENAI_IMAGE_LOW_SQUARE_ESTIMATE_CENTS=2
OPENAI_IMAGE_LOW_RECTANGULAR_ESTIMATE_CENTS=2
OPENAI_IMAGE_MEDIUM_SQUARE_ESTIMATE_CENTS=6
OPENAI_IMAGE_MEDIUM_RECTANGULAR_ESTIMATE_CENTS=7
OPENAI_IMAGE_HIGH_SQUARE_ESTIMATE_CENTS=20
OPENAI_IMAGE_HIGH_RECTANGULAR_ESTIMATE_CENTS=25
OPENAI_IMAGE_REFERENCE_RESERVE_CENTS_PER_ASSET=1
MAX_IMAGE_GENERATION_RETRIES=1
MAX_REFERENCE_ASSETS_PER_GENERATION=8
MAX_REFERENCE_BYTES_PER_GENERATION=20971520
MAX_IMAGE_GENERATIONS_PER_SCENE_VERSION=50
ENABLE_SCENE_IMAGE_GENERATION=true

# Phase 6 storyboard bulk image generation (server only)
MAX_IMAGES_PER_BATCH=25
# Phase 7 scene narration audio generation (server and Trigger.dev)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3
OPENAI_TTS_SPEED_SCALED_PERCENT=100
OPENAI_TTS_COST_PER_MILLION_CHARACTERS_CENTS=1500
OPENAI_TTS_MINIMUM_ESTIMATE_CENTS=1
MAX_AUDIO_GENERATION_RETRIES=1
MAX_AUDIO_GENERATIONS_PER_SCENE_VERSION=50
MAX_SCENES_PER_AUDIO_BATCH=25
MAX_NARRATION_CHARACTERS=4000
AUDIO_SCENE_PADDING_MILLISECONDS=250
FFPROBE_PATH=ffprobe
ENABLE_SCENE_AUDIO_GENERATION=true

# Phase 8 subtitles and timeline (Vercel web runtime only)
SUBTITLE_MAX_LINE_CHARACTERS=42
SUBTITLE_MIN_SEGMENT_DURATION_MILLISECONDS=700
SUBTITLE_MAX_SEGMENT_DURATION_MILLISECONDS=7000
SUBTITLE_DURATION_MISMATCH_TOLERANCE_MILLISECONDS=1500
ENABLE_SUBTITLES=true

# Phase 9 video preview and rendering
# Shared cost/limit/enable values go to BOTH Vercel and Trigger.dev and must
# match. The encoder/browser settings (concurrency, timeout, CRF, JPEG quality,
# Chromium path) are Trigger.dev worker only.
ENABLE_VIDEO_RENDERING=true
VIDEO_RENDER_COST_PER_MINUTE_CENTS=5
VIDEO_RENDER_MINIMUM_ESTIMATE_CENTS=5
MAX_RENDER_DURATION_SECONDS=900
MAX_RENDER_ATTEMPTS=2
VIDEO_RENDER_RESERVATION_EXPIRY_MINUTES=60
VIDEO_WATERMARK_ENABLED=false
VIDEO_WATERMARK_TEXT=
# Signed URL lifetime for the in-browser preview player (web runtime only).
VIDEO_PREVIEW_URL_EXPIRY_SECONDS=3600
VIDEO_RENDER_CONCURRENCY=1
VIDEO_RENDER_TIMEOUT_SECONDS=1800
VIDEO_RENDER_CRF=18
VIDEO_RENDER_JPEG_QUALITY=80
# REMOTION_CHROMIUM_EXECUTABLE=

# Phase 10 usage, budgets, and audit (Vercel web runtime only)
# The web runtime resolves a workspace's effective budgets (the editable
# workspace_budget_settings row, falling back to DEFAULT_DAILY/MONTHLY above) and
# decides whether an estimate crosses the manual-confirmation threshold, so this
# is a Vercel-only preflight/UX value that no Trigger.dev worker reads.
MANUAL_CONFIRMATION_THRESHOLD_CENTS=100
# Per-workspace fixed-window rate limiting for billable operations (web runtime).
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GENERATIONS_PER_WINDOW=30
RATE_LIMIT_RENDERS_PER_WINDOW=10

# Platform publishing — uploading a finished render to an external platform.
# YouTube ships first; Facebook/Instagram/TikTok reuse the same connection and
# publication tables and add their own OAuth client block here.
#
# Public origin used to build OAuth redirect URIs. It MUST match a redirect URI
# registered on the OAuth client, e.g. {APP_BASE_URL}/api/youtube/callback.
APP_BASE_URL=http://localhost:3000
# 32 bytes, base64 or hex. Encrypts platform OAuth access/refresh tokens at rest
# (AES-256-GCM). Generate with: openssl rand -base64 32
# Rotating this invalidates every stored connection — users must reconnect.
PLATFORM_TOKEN_ENCRYPTION_KEY=
# Signs the OAuth `state` parameter so a callback cannot be forged or replayed.
# Generate with: openssl rand -base64 32
OAUTH_STATE_SECRET=
OAUTH_STATE_TTL_SECONDS=600
# Google Cloud OAuth 2.0 **web** client (NOT a service account — a service
# account has no YouTube channel and cannot upload to one).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Meta app credentials are required only in the Vercel/web runtime.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Shared by Vercel and Trigger.dev. Pin this for reproducible API behavior.
FACEBOOK_GRAPH_API_VERSION=v25.0
ENABLE_VIDEO_PUBLISHING=true
MAX_PUBLISH_VIDEO_BYTES=1073741824
# Must exceed the publish task's wall clock or the R2 download URL expires
# mid-upload (the same failure mode that previously stalled long renders).
PUBLISH_ASSET_URL_TTL_SECONDS=3600
